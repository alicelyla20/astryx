generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // Hashed
  createdAt DateTime @default(now())
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  colorHex    String   // e.g., "#8B5CF6"
  energyLevel EnergyLevel @default(MEDIUM)
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  // A Category now has many Chains and Tasks
  chains      Chain[]
}

model Chain {
  id          String   @id @default(cuid())
  name        String
  type        ChainType @default(SKILL)
  
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  // A Chain has many Events and Tasks
  events      ChainEvent[]
  tasks       Task[]

  @@unique([categoryId, name]) // A chain name must be unique within its category
}

model ChainEvent {
  id          String   @id @default(cuid())
  
  chainId     String
  chain       Chain    @relation(fields: [chainId], references: [id], onDelete: Cascade)
  
  content     String   // Plain text with line breaks
  link        String?  // Optional clickable URL
  
  energyLevel EnergyLevel @default(MEDIUM)
  motivation  MotivationType?
  
  socialBattery     Int?     // 1 to 5, MOVED FROM DailyLog
  dissociationLevel Int?     // 1 to 5, MOVED FROM DailyLog
  tranquilityLevel  Int?     // 1 to 5, MOVED FROM DailyLog
  isArchived        Boolean  @default(false) // Added for event-level archive
  createdAt         DateTime @default(now()) // Acts as the event date
}

model DailyLog {
  id                String   @id @default(cuid())
  date              DateTime @unique
  tasks             Task[]
}

model Task {
  id            String          @id @default(cuid())
  title         String
  type          TaskType        // ROUTINE or TECHNICAL
  energyLevel   EnergyLevel     @default(MEDIUM)
  
  chainId       String
  chain         Chain           @relation(fields: [chainId], references: [id], onDelete: Cascade)
  
  dailyLogId    String
  dailyLog      DailyLog        @relation(fields: [dailyLogId], references: [id])
  
  status        TaskStatus      @default(PLANNED)
  motivation    MotivationType? // Filled via pop-up on completion
  
  createdAt     DateTime        @default(now())
}

enum EnergyLevel {
  LOW
  MEDIUM
  HIGH
}

enum TaskType {
  ROUTINE
  TECHNICAL
}

enum TaskStatus {
  PLANNED
  COMPLETED
  PENDING
}

enum MotivationType {
  GENUINE_INTEREST
  OBLIGATION
}

model JournalEntry {
  id        String   @id @default(cuid())
  date      DateTime @unique // Locked to Argentina Time
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ChainType {
  SKILL
  ROUTINE
}
